{
  "expo": {
    "name": "DownloadDash",
    "slug": "downloaddash",
    "version": "1.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to save downloaded content."
      }
    },
    "android": {
      "package": "com.downloaddash.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-ads-admob",
        {
          "userTrackingPermission": "This app needs permission to track your behavior to show personalized ads based on your activity."
        }
      ]
    ],
    "extra": {
